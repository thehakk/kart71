# Production (tek servis — istemci + sunucu ayni host)
NODE_ENV=production
PORT=3001
CLIENT_ORIGIN=https://your-domain.com

# Ayri istemci build icin (opsiyonel; bos birakilirsa ayni origin kullanilir)
# VITE_SERVER_URL=https://your-domain.com

# Google AdSense (client/.env.production veya Vercel env)
# VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# VITE_ADSENSE_SLOT_LOBBY=1234567890
# ads.txt: client/public/ads.txt dosyasina pub-ID ekleyin
